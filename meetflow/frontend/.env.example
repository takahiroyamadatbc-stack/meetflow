# cdk deploy後、MeetFlowAuthStack / MeetFlowApiStack のCfnOutputから転記する。
# 実際の値は .env.development （gitignore対象）に書くこと。
VITE_API_BASE_URL=https://xxxxxxxxxx.execute-api.ap-northeast-1.amazonaws.com/dev
VITE_COGNITO_USER_POOL_ID=ap-northeast-1_xxxxxxxxx
VITE_COGNITO_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_REGION=ap-northeast-1

# Web Push用VAPID公開鍵。Secrets Managerに投入した鍵ペア（vapidPublicKey）と
# 同じ値を転記する。公開鍵は秘匿情報ではないためビルド成果物への埋め込みで
# 問題ない（漏洩時は鍵ペア自体をローテーションし、この値も併せて更新する）。
VITE_VAPID_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
