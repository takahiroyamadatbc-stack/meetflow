# vitest実行時（mode=test）にVite/vitestが自動的に読み込むテスト専用の環境変数。
# 実際のAWSリソースには接続せず、MSWがすべてのHTTPリクエストをインターセプトする前提のダミー値。
VITE_API_BASE_URL=http://localhost/api
VITE_COGNITO_USER_POOL_ID=ap-northeast-1_testpool
VITE_COGNITO_USER_POOL_CLIENT_ID=test-client-id
VITE_COGNITO_REGION=ap-northeast-1
VITE_VAPID_PUBLIC_KEY=test-vapid-public-key
